# ============================================================
# КАПИТАЛЬ — пример окружения. Скопируй в .env и заполни.
# ============================================================

# --- Environment ---
ENVIRONMENT=development            # development | production
DEBUG=true

# --- Database ---
# dev (Windows, без Docker):
DATABASE_URL=sqlite+aiosqlite:///./kapital.db
# prod (Docker): должен совпадать с POSTGRES_* ниже.
# DATABASE_URL=postgresql+asyncpg://kapital:password@postgres:5432/kapital

# --- Docker Compose: Postgres (prod) ---
# Используются сервисами postgres/backup; DATABASE_URL выше должен ссылаться на эти же значения.
POSTGRES_USER=kapital
POSTGRES_PASSWORD=
POSTGRES_DB=kapital
BACKUP_RETENTION_DAYS=14

# --- Docker Compose: домен/edge nginx (prod) ---
DOMAIN=kapital.app                 # для TLS (Let's Encrypt) и reverse proxy

# --- Auth ---
JWT_SECRET=change_me_min_32_chars_long_random_string_here
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Field encryption at rest (Fernet, NFR-001) ---
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ============================================================
# LLM — провайдер-агностичный реестр ролей.
# Формат: "<provider>:<model>"  (anthropic | openai | google_genai | groq | ollama ...)
# Меняешь провайдера здесь — код агентов не трогается.
# ============================================================
LLM_PARSER=anthropic:claude-sonnet-4-6
LLM_ADVISOR=anthropic:claude-sonnet-4-6
LLM_VISION=anthropic:claude-sonnet-4-6
LLM_SUPERVISOR=anthropic:claude-haiku-4-5
LLM_NEWS_RANK=anthropic:claude-haiku-4-5
LLM_SCENARIO=anthropic:claude-haiku-4-5

# Ключи провайдеров (заполнить те, что используются в реестре выше)
# OPENAI_API_KEY нужен для Whisper STT (и для openai:* моделей).
# ВАЖНО: не оставляй комментарий в строке после "=" у ПУСТОГО значения —
# dotenv утащит его в само значение.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# --- Speech-to-text ---
STT_PROVIDER=openai                # openai (whisper-1) | local | groq
STT_LANGUAGE=ru

# --- Market data ---
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
# COINGECKO_API_KEY — опционально, есть бесплатный tier
COINGECKO_API_KEY=
NEWS_API_KEY=

# --- Payments ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
COINGATE_API_TOKEN=
COINGATE_WEBHOOK_SECRET=
COINGATE_SANDBOX=true

# --- Email (transactional) ---
EMAIL_PROVIDER=console             # console (dev) | resend | postmark | ses
EMAIL_FROM=noreply@kapital.app
RESEND_API_KEY=

# --- Redis / Celery (prod) ---
REDIS_URL=redis://localhost:6379/0

# --- Observability ---
# SENTRY_DSN — backend errors (пусто = выкл); incident_id в 500
SENTRY_DSN=
LANGCHAIN_TRACING_V2=false         # true + LANGCHAIN_API_KEY → трейсы графов в LangSmith
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=kapital-dev
# GIT_SHA задаётся CI/деплоем (release-тег для Sentry); локально не нужен.

# --- Frontend (build-time, для Vite) ---
# В prod SPA и API на одном origin (reverse proxy маршрутизирует /api → backend),
# поэтому относительный путь по умолчанию подходит. Переопредели, если API на другом хосте.
VITE_API_BASE_URL=/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_SENTRY_DSN — frontend errors (пусто = выкл)
# VITE_PLAUSIBLE_DOMAIN — аналитика (Plausible, cookieless; пусто = выкл)
# VITE_PLAUSIBLE_SRC — переопредели для self-hosted Plausible
VITE_SENTRY_DSN=
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SRC=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173
