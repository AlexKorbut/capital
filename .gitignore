node_modules/
dist/
.vite/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log

# LangGraph / checkpoints
*.checkpoint
checkpoints/

# Local run scratch (logs, tokens, scratch CSVs) — never commit
.run/
*.local

# Build output
build/
coverage/
